{
  "name": "maplephp/unitary-app",
  "type": "project",
  "description": "Starter project for Unitary, providing a ready-to-run CLI testing environment with example configuration and structure for building unit, integration, and extended test workflows.",
  "keywords": [
    "cli",
    "framework",
    "psr",
    "php",
    "mvc"
  ],
  "homepage": "https://maplephp.wazabii.se/",
  "license": "Apache-2.0",
  "authors": [
    {
      "name": "Daniel Ronkainen",
      "email": "daniel.ronkainen@wazabii.se"
    },
    {
      "name": "Unitary app",
      "homepage": "https://maplephp.github.io/Unitary/"
    }
  ],
  "require": {
    "php": ">=8.2",
    "maplephp/unitary": "*",
    "maplephp/log": "^v2.0.0"
  },
  "repositories": [
    {
      "type": "path",
      "url": "../Unitary",
      "options": {
        "symlink": true
      }
    }
  ],
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "minimum-stability": "dev"
}
