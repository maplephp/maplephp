{
  "name": "maplephp/maple",
  "type": "project",
  "description": "MaplePHP is a high performance PHP framework built on PSR standards and modern best practices.",
  "keywords": [
    "framework",
    "psr",
    "php",
    "mvc",
    "di"
  ],
  "homepage": "https://wazabii.se/",
  "license": "Apache-2.0",
  "authors": [
    {
      "name": "Daniel Ronkainen",
      "email": "daniel.ronkainen@wazabii.se"
    }
  ],
  "scripts": {
    "test": "vendor/bin/unitary",
    "serve": [
      "Composer\\Config::disableProcessTimeout",
      "./maple serve"
    ]
  },
  "require": {
    "php": ">=8.2",
    "maplephp/core": "^1.0"
  },
  "require-dev": {
    "maplephp/unitary": "^2.1"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Configs\\": "configs/",
      "Migrations\\": "database/migrations"
    }
  },
  "extra": {
    "branch-alias": {
      "dev-main": "1.x-dev",
      "dev-develop": "1.x-dev"
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
