{% extends 'index.twig' %}

{% block content %}
    <h1>{{ title }}</h1>

    <p class="meta">Rendered with Twig on {{ rendered_at }}</p>
    <p class="greeting">Hello, <strong>{{ name }}</strong>!</p>

    {% if items is not empty %}
        <h2>Items</h2>
        <ul class="items">
            {% for item in items %}
                <li>{{ loop.index }}. {{ item }}</li>
            {% endfor %}
        </ul>
    {% endif %}

    <p><a href="/">&laquo; Back home</a></p>
{% endblock %}
