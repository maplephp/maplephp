<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ title ?? 'Your title' }}{% endblock %} | {{ app.app_title }}</title>
    <style>
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        max-width: 800px;
        margin: 80px auto;
        padding: 0 24px;
        color: #1a1a1a;
      }

      h1 {
        font-size: 2rem;
        margin-bottom: 0.25rem;
      }

      .meta {
        color: #666;
        margin-bottom: 2rem;
      }

      .greeting {
        font-size: 1.25rem;
        margin-bottom: 1rem;
      }

      .items {
        list-style: none;
        padding: 0;
      }

      .items li {
        padding: 10px 16px;
        background: #f5f5f5;
        border-radius: 6px;
        margin-bottom: 8px;
      }
    </style>
    {% block head %}{% endblock %}
</head>
<body>
<main>
    {% block content %}{% endblock %}
</main>
</body>
</html>
