<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            max-width: 800px;
            margin: 80px auto;
            padding: 0 24px;
            color: #1a1a1a;
        }
        h1 { font-size: 2rem; margin-bottom: 0.25rem; }
        .meta { color: #666; margin-bottom: 2rem; }
        .greeting { font-size: 1.25rem; margin-bottom: 1rem; }
        .items { list-style: none; padding: 0; }
        .items li {
            padding: 10px 16px;
            background: #f5f5f5;
            border-radius: 6px;
            margin-bottom: 8px;
        }
    </style>
</head>
<body>
    <h1>{{ title }}</h1>
    <p class="meta">Rendered with Twig on {{ rendered_at }}</p>

    <p class="greeting">Hello, <strong>{{ name }}</strong>!</p>

    {% if items is not empty %}
        <h2>Items</h2>
        <ul class="items">
            {% for item in items %}
                <li>{{ loop.index }}. {{ item }}</li>
            {% endfor %}
        </ul>
    {% endif %}

    <p><a href="/">← Back home</a></p>
</body>
</html>
